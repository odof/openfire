<?xml version="1.0" encoding="utf-8"?>

<odoo>
    <data noupdate="1">

        <!-- Website Fuel Choice Email template  -->
        <record id="of_website_fuel_choice_mail_template" model="mail.template">
            <field name="name">Demande de combustible</field>
            <field name="email_from">${object.email or ''}</field>
            <field name="email_to">${object.email or ''}</field>
            <field name="subject">Demande de devis pour combustible</field>
            <field name="model_id" ref="base.model_res_company"/>
            <field name="auto_delete" eval="False"/>
            <field name="body_html"/>
        </record>

    </data>
</odoo>
