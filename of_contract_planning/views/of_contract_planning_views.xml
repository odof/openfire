<?xml version="1.0" encoding="utf-8"?>
<odoo>

<!-- ******************************************************************************************* -->
<!-- ***************************************** CONTRAT ***************************************** -->
<!-- ******************************************************************************************* -->

    <record id="act_recurring_invoices" model="ir.actions.act_window">
        <field name="name">Invoices</field>
        <field name="res_model">account.invoice</field>
        <field name="view_ids"
               eval="[(5, 0, 0),
                      (0, 0, {'view_mode': 'tree', 'view_id': ref('account.invoice_tree')}),
                      (0, 0, {'view_mode': 'form', 'view_id': ref('account.invoice_form')})]"/>
        <field name="context">{
            'search_default_of_contract_id': [active_id],
            'default_of_contract_id': active_id}
        </field>
    </record>

    <record id="of_contract_tree_view" model="ir.ui.view">
        <field name="name">of_contract_tree_view</field>
        <field name="model">of.contract</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="partner_id"/>
                <field name="recurring_interval"/>
                <field name="recurring_rule_type"/>
                <field name="recurring_invoicing_type"/>
            </tree>
        </field>
    </record>

    <record id="of_contract_form_view" model="ir.ui.view">
        <field name="name">of_contract_form_view</field>
        <field name="model">of.contract</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="recurring_create_invoice" type="object" class="btn-primary" string="Créer les factures"/>
                </header>
                <div class="oe_button_box" name="button_box">
                    <button class="oe_stat_button" type="object" name="action_view_invoice" icon="fa-pencil-square-o">
                        <field name="invoice_count" widget="statinfo" string="Factures"/>
                    </button>
                </div>
                <div class="oe_title">
                    <label for="name" class="oe_edit_only"/>
                    <h1>
                        <field name="name" class="oe_inline" placeholder="e.g. Project XYZ"/>
                    </h1>
                </div>
                <group>
                    <field name="partner_id"/>
                    <field name="company_id"/>
                </group>
                <separator string="Factures récurrentes"/>
                <group col="4">
                    <group col="2" colspan="2">
<!--                         <field name="contract_template_id" colspan="4"/> -->
                        <field name="recurring_invoicing_type"/>
                        <label for="recurring_interval"/>
                        <div>
                            <field name="recurring_interval" class="oe_inline"/>
                            <field name="recurring_rule_type" class="oe_inline"/>
                        </div>
                        <field name="date_start"/>
                        <field name="recurring_next_date"/>
                    </group>
                    <group col="2" colspan="2">
                        <field name="journal_id"/>
                        <field name="pricelist_id"/>
                        <field name="date_end"/>
                        <field name="fiscal_position_id"/>
                    </group>
                </group>
                <separator string="Lignes"/>
                <group>
                    <field name="service_ids" mode="tree" nolabel="1"
                           context="{'form_view_ref': 'of_contract_planning.of_contract_view_of_service_parc_installe_service_form',
                                     'default_partner_id': partner_id,
                                     'default_frequency_type': recurring_rule_type,
                                     'recurring_next_date': recurring_next_date}">
                        <tree>
                            <field name="sequence" widget="handle"/>
                            <field name="product_id"/>
                            <field name="quantity"/>
                            <field name="uom_id"/>
                            <field name="automatic_price"/>
                            <field name="specific_price" invisible="1"/>
                            <field name="price_unit"/>
                            <field name="price_subtotal"/>
                            <field name="discount"/>
                            <field name="frequency"/>
                            <field name="frequency_type"/>
                            <field name="previous_date"/>
                            <field name="next_date"/>
                            <field name="parc_installe_id"/>
                            <field name="intervention_model_id"/>
                        </tree>
                    </field>
                </group>
                <group class="oe_subtotal_footer oe_right">
                    <field name="company_currency_id" invisible="1"/>
                    <field name="next_subtotal"/>
                    <field name="next_taxes"/>
                    <field name="next_total" class="oe_subtotal_footer_separator"/>
                </group>
            </form>
        </field>
    </record>

    <record id="action_contract" model="ir.actions.act_window">
        <field name="name">Contrats</field>
        <field name="res_model">of.contract</field>
        <field name="view_type">form</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="of_contract_tree_view"/>
    </record>

    <menuitem name="Contrats" id="menu_contrats" parent="of_planning.menu_of_planning_intervention" sequence="80" action="action_contract"/>

<!-- ******************************************************************************************* -->
<!-- ***************************************** SERVICE ***************************************** -->
<!-- ******************************************************************************************* -->

    <record id="of_contract_view_of_service_parc_installe_service_form" model="ir.ui.view">
        <field name="name">of_contract_view_of_service_parc_installe_service_form</field>
        <field name="model">of.service</field>
        <field name="inherit_id" ref="of_service_parc_installe.view_of_service_parc_installe_service_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='tache_id']" position="before">
                <field name="intervention_model_id"/>
            </xpath>
            <xpath expr="//field[@name='tache_id']" position="attributes">
                <attribute name="attrs">{'required': [('intervention_model_id', '!=', False)]}</attribute>
            </xpath>
            <xpath expr="//field[@name='address_id']" position="attributes">
                <attribute name="attrs">{'required': ['|', ('intervention_model_id', '!=', False), ('tache_id', '!=', False)]}</attribute>
            </xpath>
<!--             <xpath expr="//field[@name='name']" position="attributes"> -->
<!--                 <attribute name="attrs">{'required': ['|', ('intervention_model_id', '!=', False), ('tache_id', '!=', False)]}</attribute> -->
<!--             </xpath> -->
            <xpath expr="//field[@name='mois_ids']" position="attributes">
                <attribute name="attrs">{'required': ['|', ('intervention_model_id', '!=', False), ('tache_id', '!=', False)]}</attribute>
            </xpath>
            <xpath expr="//field[@name='jour_ids']" position="attributes">
                <attribute name="attrs">{'required': ['|', ('intervention_model_id', '!=', False), ('tache_id', '!=', False)]}</attribute>
            </xpath>
            <xpath expr="//field[@name='date_next']" position="attributes">
                <attribute name="attrs">{'required': ['|', ('intervention_model_id', '!=', False), ('tache_id', '!=', False)]}</attribute>
            </xpath>
            <xpath expr="//notebook" position="inside">
                <page name="invoicing" string="Facturation">
                    <group>
                        <field name="sequence"/>
                        <field name="product_id"/>
                        <field name="product_name" attrs="{'required': [('product_id', '!=', False)]}"/>
                        <field name="quantity" attrs="{'required': [('product_id', '!=', False)]}"/>
                        <field name="uom_id" attrs="{'required': [('product_id', '!=', False)]}"/>
                        <field name="automatic_price"/>
                        <field name="specific_price" invisible="1"/>
                        <field name="price_unit"/>
                        <field name="price_subtotal"/>
                        <field name="discount"/>
                        <field name="frequency" attrs="{'required': [('product_id', '!=', False)]}"/>
                        <field name="frequency_type" attrs="{'required': [('product_id', '!=', False)]}"/>
                        <field name="previous_date"/>
                        <field name="next_date"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

</odoo>
