<?xml version="1.0" encoding="utf-8"?>
<odoo>


    <act_window
        name="Planifier une intervention"
        res_model="of.tournee.rdv"
        src_model="of.contract"
        view_mode="form"
        view_id="of_planning_tournee.view_rdv_intervention_wizard"
        id="action_view_rdv_contract_wizard_client"
        key2="client_action_multi"
        target="new"
    />

    <!-- Ajout bouton planifier une intervention dans vue form partenaire-->
    <record id="of_contract_form_view_wizard" model="ir.ui.view">
        <field name="name">of.contract.form.view.wizard</field>
        <field name="model">of.contract</field>
        <field name="inherit_id" ref="of_contract_planning.of_contract_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="%(action_view_rdv_contract_wizard_client)d" string="Planifier Intervention" type="action"/>
            </xpath>
        </field>
    </record>

</odoo>