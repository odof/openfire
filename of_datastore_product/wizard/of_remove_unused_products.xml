<?xml version="1.0" encoding="utf-8"?>
<openerp>
    <data>

        <record id="view_of_remove_unused_products_form" model="ir.ui.view">
            <field name="name">of.remove.unused.products.form</field>
            <field name="model">of.remove.unused.products</field>
            <field name="type">form</field>
            <field name="arch" type="xml">
                <form string="Suppression des produits inutilisés">
                    <group colspan="4">
                        <field name="partner_id"/>
                    </group>
                    <group colspan="4" attrs="{'invisible':[('product_ids','=',False)]}">
                        <separator colspan="4" string="Produits à supprimer"/>
                        <field name="product_ids" nolabel="1" colspan="4"/>
                    </group>
                    <group colspan="4">
                        <separator colspan="4"/>
                        <button icon="gtk-cancel" name="show_unused_products" type="object" string="Afficher les produits inutilisés"/>
                        <button icon="gtk-cancel" special="cancel" string="Annuler"/>
                        <button icon="gtk-ok" name="remove_unused_products" type="object" string="Supprimer les produits inutilisés"/>
                    </group>
                    
                </form>
            </field>
        </record>

        <record id="action_of_remove_unused_products" model="ir.actions.act_window">
            <field name="name">Suppression des produits inutilisés</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">of.remove.unused.products</field>
            <field name="view_type">form</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>

        <menuitem id="menu_of_remove_unused_products" action="action_of_remove_unused_products"
            name="Supp. produits" 
            parent="product.prod_config_main" sequence="30"
            groups="of_magasin.of_group_manager_maga"/>

    </data>
</openerp>
