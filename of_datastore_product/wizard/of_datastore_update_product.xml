<?xml version="1.0" encoding="utf-8"?>
<openerp>
    <data>

        <record id="view_of_datastore_update_product_form" model="ir.ui.view">
            <field name="name">of.datastore.update.product.form</field>
            <field name="model">of.datastore.update.product</field>
            <field name="type">form</field>
            <field name="arch" type="xml">
                <form string="Import / Mise à jour des produits">
                    <field name="is_update" invisible="1"/>
                    <group name="update" colspan="4" attrs="{'invisible': [('is_update','=',False)]}">
                        <separator colspan="4" string="Champs à mettre à jour"/>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="tarif"/>
                        <field name="cg"/>
                        <field name="categ"/>
                        <field name="act"/>
                        <field name="uom"/>
                        <field name="kit"/>
                        <field name="ds_supplier_id"/>
                    </group>
                    <group name="Notes" colspan="4" attrs="{'invisible':[('note','=',False)]}">
                        <separator colspan="4" string="Notes de mise à jour"/>
                        <field name="note" nolabel="1" colspan="4"/>
                    </group>
                    <group colspan="4">
                        <separator colspan="4"/>
                        <field name="remember" attrs="{'invisible': [('is_update','=',False)]}"/>
                    </group>
                    <group colspan="4">
                        <button icon="gtk-cancel" special="cancel" string="Annuler"/>
                        <button icon="gtk-ok" name="update_products" type="object" string="Mettre à jour" attrs="{'invisible': [('is_update','=',False)]}"/>
                        <button icon="gtk-ok" name="update_products" type="object" string="Importer" attrs="{'invisible': [('is_update','=',True)]}"/>
                    </group>
                    
                </form>
            </field>
        </record>


        <act_window id="action_of_datastore_update_product"
            key2="client_action_multi" name="Import/MAJ des produits"
            res_model="of.datastore.update.product" src_model="product.product"
            view_mode="form" target="new" view_type="form" />



    </data>
</openerp>
