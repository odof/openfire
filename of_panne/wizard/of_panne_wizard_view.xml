<?xml version="1.0"?>
<odoo>

    <record id="of_panne_wizard_view" model="ir.ui.view">
            <field name="name">Sélection d'équipe</field>
            <field name="model">of.panne.wizard</field>
            <field name="arch" type="xml">
                <form string="Sélection d'équie">
                    <group>
                        <field name="equipe_id"/>
                    </group>
                    <footer>
                        <button name="select_team" string="Valider" type="object" class="btn-primary"/>
                        <button string="Annuler" class="btn-default" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="action_of_panne_wizard_view" model="ir.actions.act_window">
            <field name="name">Sélection d'équipe</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">of.panne.wizard</field>
            <field name="view_type">form</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>

