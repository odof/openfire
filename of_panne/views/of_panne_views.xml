<?xml version="1.0"?>
<odoo>

<!-- ******************************* Pannes *******************************-->

    <record id="of_panne_filter" model="ir.ui.view">
        <field name="name">of.panne.filter</field>
        <field name="model">of.panne</field>
        <field name="arch" type="xml">
            <search string="Recherche">
                <group>
                    <filter string="À prendre en charge" name="state_todo" icon="terp-folder-violet" domain="[('state','=','todo')]"/>
                    <filter string="Prise en charge" name="state_doing" icon="terp-folder-violet" domain="[('state','=','doing')]"/>
                    <filter string="Terminée" name="state_done" icon="terp-folder-violet" domain="[('state','=','done')]"/>
                </group>
                <group>
                    <field name="partner_id"/>
                </group>
            </search>
        </field>
    </record>

    <record id="of_panne_view_form" model="ir.ui.view">
        <field name="name">of.panne.view.form</field>
        <field name="model">of.panne</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="of_panne.action_of_panne_wizard_view" string="Sélectionner équipe" type="action" class="btn-primary" attrs="{'invisible': [('state', '!=', 'todo')]}"/>
                    <field name="state" widget="statusbar" nolabel="1" statusbar_visible="todo,doing,done" readonly="1"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="toggle_active" type="object" class="oe_stat_button" icon="fa-archive">
                            <field name="active" widget="boolean_button" options="{'terminology': 'archive'}"/>
                        </button>
                        <button class="oe_stat_button" name="action_view_interventions" type="object" icon="fa-wrench">
                            <field string="Interventions" name="intervention_count" widget="statinfo"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Nom"/></h1>
                    </div>
                    <group col="4">
                        <group colspan="2">
                            <field name="partner_id"/>
                            <field name="parc_installe_id" domain="['|', ('client_id', partner_id and '=' or 'ilike', partner_id or ''), ('site_adresse_id', partner_id and '=' or 'ilike', partner_id or '')]"/>
                            <field name="intervention_model_id"/>
                            <field name="tache_id"/>
                        </group>
                        <group colspan="2">
                            <field name="equipe_id" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Notes">
                            <separator string="Notes"/>
                            <group>
                                <field name="notes"/>
                                <field name="notes_client"/>
                            </group>
                        </page>
                        <page string="Historique">
                            <group name="panne">
                                <field name="panne_ids" nolabel="1" options="{'no_delete': True, 'no_create': True}" readonly="1">
                                    <tree string="Pannes">
                                        <field name="create_date" string="Date"/>
                                        <field name="name"/>
                                        <field name="equipe_id"/>
                                        <field name="tache_id"/>
                                        <field name="state"/>
                                        <field name="notes"/>
                                    </tree>
                                </field>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="of_panne_view_tree" model="ir.ui.view">
        <field name="name">of.panne.view.tree</field>
        <field name="model">of.panne</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="partner_id"/>
                <field name="parc_installe_id"/>
                <field name="notes"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <record id="action_of_panne" model="ir.actions.act_window">
        <field name="name">Pannes</field>
        <field name="res_model">of.panne</field>
        <field name="view_type">form</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="of_panne.of_panne_view_tree"/>
    </record>

    <menuitem name="Pannes" id="menu_of_secteur_config" parent="of_planning.menu_of_planning_intervention" sequence="1" action="of_panne.action_of_panne"/>

<!-- **************************** Interventions ***************************-->

    <record id="of_panne_of_planning_intervention_view_form" model="ir.ui.view">
        <field name="name">of.panne.of.planning.intervention.view.form</field>
        <field name="model">of.planning.intervention</field>
        <field name="inherit_id" ref="of_planning.of_planning_intervention_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='liens']" position="inside">
                <field name="panne_id" domain="[('partner_id', '=', address_id)])" context="{'default_partner_id': address_id, 'default_tache_id': tache_id, 'default_intervention_model_id' : model_id}"/>
            </xpath>
        </field>
    </record>

<!-- **************************** Parc installe ***************************-->

    <record id="of_panne_of_parc_installe_form_view" model="ir.ui.view">
        <field name="name">of.panne.of.parc.installe.form.view</field>
        <field name="model">of.parc.installe</field>
        <field name="inherit_id" ref="of_parc_installe.of_parc_installe_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Historique Panne">
                    <group name="panne">
                        <field name="panne_ids" nolabel="1" options="{'no_delete': True, 'no_create': True}" readonly="1">
                            <tree string="Pannes">
                                <field name="create_date" string="Date"/>
                                <field name="name"/>
                                <field name="equipe_id"/>
                                <field name="tache_id"/>
                                <field name="state"/>
                                <field name="notes"/>
                            </tree>
                        </field>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

</odoo>
